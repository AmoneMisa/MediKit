# Copy to .env and adjust as needed.
PORT=4000
# Secret used to sign JWTs. CHANGE THIS in production.
JWT_SECRET=change-me-in-production

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Either set DATABASE_URL directly...
# DATABASE_URL=postgres://medikit:medikit@localhost:5432/medikit
# ...or provide the individual parts (used by docker-compose too):
PGUSER=medikit
PGPASSWORD=medikit
PGHOST=localhost
PGPORT=5432
PGDATABASE=medikit

# Set to 'false' to disable live openFDA/RxNav lookups (offline/air-gapped).
ENABLE_GLOBAL_SOURCES=true
